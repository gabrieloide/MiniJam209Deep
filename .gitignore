# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# MemoryCaptures can get excessive
/[Mm]emoryCaptures/

# Recordings can get excessive
/[Rr]ecordings/

# Asset store packages can be redistributed, they should be ignored
/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains projects
/cmake-build-*/
/.idea/
/*.sln
/*.csproj
/*.unityproj

# Visual Studio cache directory
.vs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Secret configuration files
**/Secret/*.asset
**/Secret/*.asset.meta
